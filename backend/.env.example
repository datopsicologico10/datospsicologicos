# ============================================================
#  PSYCHOLOGY SHORTS AUTOMATION — Variables de Entorno
#  Solo se paga Claude API. Todo lo demás es GRATIS.
# ============================================================

# --- Anthropic (Claude) — ÚNICA API DE PAGO ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- TTS: Microsoft Edge TTS (GRATIS, sin API key) ---
# Voces disponibles en español:
#   es-ES-AlvaroNeural    (hombre, España)
#   es-ES-ElviraNeural    (mujer, España)
#   es-MX-JorgeNeural     (hombre, México)
#   es-MX-DaliaNeural     (mujer, México)
EDGE_TTS_VOICE=es-ES-AlvaroNeural
EDGE_TTS_RATE=+10%        # Velocidad (+10% = ligeramente más rápido)
EDGE_TTS_PITCH=+0Hz       # Tono (0 = natural)

# --- TikTok (gratis con cuenta developer) ---
TIKTOK_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Instagram / Meta (gratis con cuenta business) ---
INSTAGRAM_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
INSTAGRAM_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- YouTube (gratis con cuenta Google) ---
YOUTUBE_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
YOUTUBE_REFRESH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Base de datos: SQLite (GRATIS, archivo local) ---
SQLITE_DB_PATH=./data/psychology_shorts.db

# --- Paths ---
OUTPUT_DIR=./output
ASSETS_DIR=./assets
QUEUE_DIR=./queue
FFMPEG_PATH=ffmpeg          # Asegúrate de que ffmpeg esté en PATH

# --- Configuración de publicación ---
PUBLISH_TIMES_CET=15:00,18:00,21:00
VIDEOS_PER_DAY=3
MIN_VIRALITY_SCORE=70
TARGET_DURATION_SECONDS=58

# --- Servidor ---
PORT=3000
NODE_ENV=development

# --- Zona horaria ---
TZ=Europe/Madrid
